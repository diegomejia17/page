---

---

<section
    id="inicio"
    class="relative pt-32 pb-20 px-6 min-h-screen flex items-center justify-center bg-brand-bg overflow-hidden"
>
    <!-- Background Blur Effect -->
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-brand-light-green/20 rounded-full blur-[120px] -z-10"
    >
    </div>

    <div class="max-w-4xl mx-auto text-center space-y-8">
        <!-- Badge -->
        <div
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-brand-green/30 bg-white/50 backdrop-blur-sm"
        >
            <span class="w-2 h-2 rounded-full bg-brand-green animate-pulse"
            ></span>
            <span
                class="text-xs font-medium text-brand-dark-green tracking-wide uppercase"
                >Disponible para trabajar</span
            >
        </div>

        <!-- Headache -->
        <h1
            class="text-5xl md:text-7xl font-bold tracking-tight text-brand-dark-green text-balance"
        >
            Transformando ideas en
            <span class="text-brand-green">productos digitales</span>
        </h1>

        <!-- Subtitle -->
        <p
            class="text-lg md:text-xl text-neutral-600 max-w-2xl mx-auto text-balance leading-relaxed"
        >
            Diseñador y desarrollador enfocado en crear experiencias web únicas,
            funcionales y accesibles para potenciar tu negocio.
        </p>

        <!-- CTAs -->
        <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4"
        >
            <a
                href="#proyectos"
                class="px-8 py-3 bg-brand-light-green text-brand-dark-green font-semibold rounded-full hover:scale-105 transition-transform"
            >
                Mis Proyectos
            </a>
            <a
                href="#contacto"
                class="px-8 py-3 border border-brand-dark-green/20 text-brand-dark-green font-semibold rounded-full hover:bg-white hover:border-transparent hover:shadow-lg transition-all"
            >
                Contáctame
            </a>
        </div>

        <!-- Social Links -->
        <div class="flex items-center justify-center gap-6 pt-8">
            <a
                href="#"
                class="text-neutral-500 hover:text-brand-dark-green transition-colors"
            >
                <span class="sr-only">LinkedIn</span>
                <svg
                    class="h-6 w-6"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path
                        fill-rule="evenodd"
                        d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
            <a
                href="#"
                class="text-neutral-500 hover:text-brand-dark-green transition-colors"
            >
                <span class="sr-only">GitHub</span>
                <svg
                    class="h-6 w-6"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path
                        fill-rule="evenodd"
                        d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>
    </div>
</section>
