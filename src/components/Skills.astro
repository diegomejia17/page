---

---

<section
    id="habilidades"
    class="bg-brand-slate py-20 px-6 text-white border-t border-brand-slate-light"
>
    <div class="max-w-7xl mx-auto space-y-16">
        <!-- Header -->
        <div class="text-center space-y-4">
            <h2 class="text-3xl md:text-4xl font-bold">
                Habilidades y herramientas
            </h2>
            <div class="h-1 w-20 bg-brand-light-green rounded-full mx-auto">
            </div>
        </div>

        <!-- Skills Cards -->
        <div class="grid md:grid-cols-3 gap-8">
            <!-- Col 1 -->
            <div
                class="bg-brand-slate-light/60 p-8 rounded-3xl border border-white/5 hover:bg-brand-slate-light transition-colors"
            >
                <div
                    class="flex items-center gap-4 text-brand-light-green mb-6"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-brand-dark-green rounded-tl-sm rounded-br-sm shadow-sm"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">
                        Gestión de producto
                    </h3>
                </div>
                <ul class="space-y-3 text-neutral-300 text-sm pl-2">
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Estrategia de producto
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Planeación de hoja de ruta
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Historias de usuario
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Metodologías ágiles
                    </li>
                </ul>
            </div>

            <!-- Col 2 -->
            <div
                class="bg-brand-slate-light/60 p-8 rounded-3xl border border-white/5 hover:bg-brand-slate-light transition-colors"
            >
                <div
                    class="flex items-center gap-4 text-brand-light-green mb-6"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-brand-dark-green rounded-tl-sm rounded-br-sm shadow-sm"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">Diseño y UX</h3>
                </div>
                <ul class="space-y-3 text-neutral-300 text-sm pl-2">
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Diseño UI/UX
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Prototipado
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Diseño de sistema
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Diseño responsive
                    </li>
                </ul>
            </div>

            <!-- Col 3 -->
            <div
                class="bg-brand-slate-light/60 p-8 rounded-3xl border border-white/5 hover:bg-brand-slate-light transition-colors"
            >
                <div
                    class="flex items-center gap-4 text-brand-light-green mb-6"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-brand-dark-green rounded-tl-sm rounded-br-sm shadow-sm"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">Desarrollo</h3>
                </div>
                <ul class="space-y-3 text-neutral-300 text-sm pl-2">
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        HTML/CSS/JS
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        React
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        n8n Automation
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Git
                    </li>
                </ul>
            </div>
        </div>

        <!-- Tools -->
        <div class="space-y-8">
            <h4 class="text-center text-xl font-bold text-white">
                Herramientas principales
            </h4>

            <div
                class="flex flex-wrap items-center justify-center gap-4 md:gap-6"
            >
                <!-- Tool 1: n8n -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-green"
                    >
                        <path
                            d="M12.8 2.2l5.6 3.2v6.4l-5.6 3.2-5.6-3.2V5.4l5.6-3.2zm0 19.6l-5.6-3.2V12l5.6 3.2 5.6-3.2v6.6l-5.6 3.2zM2.6 7.6L8 11V18l-5.4-3.4V7.6zm13.4 3.4l5.4-3.4v7L16 18v-7z"
                        ></path>
                    </svg>
                    n8n
                </div>

                <!-- Tool 2: Figma -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-green"
                    >
                        <path
                            d="M12 2a4 4 0 0 0-4 4 4 4 0 0 0-4 4 4 4 0 0 0 4 4v4a4 4 0 0 0 4 4 4 4 0 0 0 4-4V2h-4zm0 12h-4a2 2 0 1 1 0-4h4v4zm0-6h-4a2 2 0 1 1 0-4h4v4zm4 0v4h-4V6h4z"
                        ></path>
                    </svg>
                    Figma
                </div>

                <!-- Tool 3: Jira -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-green"
                    >
                        <path
                            d="M11.53 2c0 2.4 1.97 4.35 4.35 4.35h1.78v1.7c0 2.4 1.94 4.35 4.34 4.35V6.35C22 3.95 20.06 2 17.65 2h-6.12zM6.6 6.35c2.4 0 4.34 1.94 4.34 4.35V17.65c0 2.4-1.95 4.35-4.34 4.35C4.2 22 2.25 20.06 2.25 17.65V10.7c0-2.4 1.95-4.35 4.35-4.35zm5.55 4.35c2.4 0 4.35 1.94 4.35 4.35V22c2.4 0 4.34-1.95 4.34-4.35V6.35c0 2.4-1.94 4.35-4.34 4.35H12.15z"
                        ></path>
                    </svg>
                    Jira
                </div>

                <!-- Tool 4: Slack -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-green"
                    >
                        <path
                            d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.522 2.521 2.527 2.527 0 0 1-2.522-2.521V2.522A2.528 2.528 0 0 1 15.166 0a2.528 2.528 0 0 1 2.522 2.522v6.312zM15.166 18.956a2.528 2.528 0 0 1 2.522 2.522A2.528 2.528 0 0 1 15.166 24a2.527 2.527 0 0 1-2.522-2.522v-2.522h2.522zM15.166 17.688a2.527 2.527 0 0 1-2.522-2.522 2.527 2.527 0 0 1 2.522-2.522h6.312A2.528 2.528 0 0 1 24 15.166a2.528 2.528 0 0 1-2.522 2.522h-6.312z"
                        ></path>
                    </svg>
                    Slack
                </div>
            </div>
        </div>
    </div>
</section>
