---

---

<section
    id="habilidades"
    class="bg-brand-slate py-20 px-6 text-white border-t border-brand-slate-light"
>
    <div class="max-w-7xl mx-auto space-y-16">
        <!-- Header -->
        <div class="text-center space-y-4">
            <h2 class="text-3xl md:text-4xl font-bold">
                Habilidades y herramientas
            </h2>
            <div class="h-1 w-20 bg-brand-light-green rounded-full mx-auto">
            </div>
        </div>

        <!-- Skills Cards -->
        <div class="grid md:grid-cols-3 gap-8">
            <!-- Col 1 -->
            <div
                class="bg-brand-slate-light/60 p-8 rounded-3xl border border-white/5 hover:bg-brand-slate-light transition-colors"
            >
                <div
                    class="flex items-center gap-4 text-brand-light-green mb-6"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-brand-dark-green rounded-tl-sm rounded-br-sm shadow-sm"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">
                        Gestión de producto
                    </h3>
                </div>
                <ul class="space-y-3 text-neutral-300 text-sm pl-2">
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Estrategia de producto
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Planeación de hoja de ruta
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Historias de usuario
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Metodologías ágiles
                    </li>
                </ul>
            </div>

            <!-- Col 2 -->
            <div
                class="bg-brand-slate-light/60 p-8 rounded-3xl border border-white/5 hover:bg-brand-slate-light transition-colors"
            >
                <div
                    class="flex items-center gap-4 text-brand-light-green mb-6"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-brand-dark-green rounded-tl-sm rounded-br-sm shadow-sm"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">Diseño y UX</h3>
                </div>
                <ul class="space-y-3 text-neutral-300 text-sm pl-2">
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Diseño UI/UX
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Prototipado
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Diseño de sistema
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Diseño responsive
                    </li>
                </ul>
            </div>

            <!-- Col 3 -->
            <div
                class="bg-brand-slate-light/60 p-8 rounded-3xl border border-white/5 hover:bg-brand-slate-light transition-colors"
            >
                <div
                    class="flex items-center gap-4 text-brand-light-green mb-6"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-brand-dark-green rounded-tl-sm rounded-br-sm shadow-sm"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">Desarrollo</h3>
                </div>
                <ul class="space-y-3 text-neutral-300 text-sm pl-2">
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        HTML/CSS/JS
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        React
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        n8n Automation
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="w-1 h-1 bg-white rounded-full"></span>
                        Git
                    </li>
                </ul>
            </div>
        </div>

        <!-- Tools -->
        <div class="space-y-8">
            <h4 class="text-center text-xl font-bold text-white">
                Herramientas principales
            </h4>

            <div
                class="flex flex-wrap items-center justify-center gap-4 md:gap-6"
            >
                <!-- Tool 1: n8n -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-light-green"
                    >
                        <path
                            d="M2 5a3 3 0 1 1 3.965 2.827.915.915 0 0 1 .035.173v5a1 1 0 0 1-2 0V8a.915.915 0 0 1 .035-.173A2.989 2.989 0 0 1 2 5Zm17.965 11.173A.915.915 0 0 0 20 16v-4a1 1 0 0 0-2 0v4a.915.915 0 0 0 .035.173 3 3 0 1 0 1.93 0ZM21 2h-4a1 1 0 0 0-1 1v1h-4a1 1 0 0 0 0 2h4v1a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1ZM12 18H8v-1a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-2h4a1 1 0 0 0 0-2Z"
                        ></path>
                    </svg>
                    n8n
                </div>

                <!-- Tool 2: Figma -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 256 256"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-light-green"
                    >
                        <path
                            d="M186.61523 94.00049a41.97934 41.97934 0 0 0-24.61523-76H94A41.97934 41.97934 0 0 0 69.38477 94.00049a41.93894 41.93894 0 0 0 .00048 67.99939A41.9892 41.9892 0 1 0 136 195.99951V160.948a41.97356 41.97356 0 1 0 50.61523-66.94751ZM188 60.001a26.02916 26.02916 0 0 1-25.98047 25.99951L162 86l-.03857.001L136 86V34.001h26A26.02947 26.02947 0 0 1 188 60.001ZM162 154a25.99952 25.99952 0 0 1-.03857-51.999H162l.019-.00049A25.99976 25.99976 0 0 1 162 154Z"
                        ></path>
                    </svg>
                    Figma
                </div>

                <!-- Tool 3: Jira -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-light-green"
                    >
                        <path
                            d="M11.571 11.513H0a5.218 5.218 0 0 0 5.232 5.215h2.13v2.057A5.215 5.215 0 0 0 12.575 24V12.518a1.005 1.005 0 0 0-1.005-1.005zm5.723-5.756H5.736a5.215 5.215 0 0 0 5.215 5.214h2.129v2.058a5.218 5.218 0 0 0 5.215 5.214V6.758a1.001 1.001 0 0 0-1.001-1.001zM23.013 0H11.455a5.215 5.215 0 0 0 5.215 5.215h2.129v2.057A5.215 5.215 0 0 0 24 12.483V1.005A1.001 1.001 0 0 0 23.013 0Z"
                        ></path>
                    </svg>
                    Jira
                </div>

                <!-- Tool 4: Slack -->
                <div
                    class="flex items-center gap-2 px-4 py-2 bg-brand-slate-light/80 rounded-full border border-white/10 text-brand-light-green font-medium hover:bg-brand-slate-light hover:border-brand-green/50 transition-colors cursor-default"
                >
                    <svg
                        viewBox="0 0 256 256"
                        fill="currentColor"
                        class="w-4 h-4 text-brand-light-green"
                    >
                        <path
                            d="M221.13184 128a31.97762 31.97762 0 0 0-37.13184-51.69478V56a31.97939 31.97939 0 0 0-56-21.132A31.97768 31.97768 0 0 0 76.30518 72H56a31.97928 31.97928 0 0 0-21.13184 56A31.97763 31.97763 0 0 0 72 179.69487V200a31.97939 31.97939 0 0 0 56 21.132A31.97768 31.97768 0 0 0 179.69482 184H200a31.97928 31.97928 0 0 0 21.13184-56ZM88 56a16 16 0 0 1 32 0V72H104A16.01833 16.01833 0 0 1 88 56ZM40 104a16.01833 16.01833 0 0 1 16-16h48a16.01833 16.01833 0 0 1 16 16v16H56a16.01833 16.01833 0 0 1-16-16Zm128 96a16 16 0 0 1-32 0V184h16a16.01833 16.01833 0 0 1 16 16Zm32-32H152a16.01833 16.01833 0 0 1-16-16V136h64a16 16 0 0 1 0 32Z"
                        ></path>
                    </svg>
                    Slack
                </div>
            </div>
        </div>
    </div>
</section>
