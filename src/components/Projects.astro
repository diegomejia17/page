---

---

<section id="proyectos" class="py-20 px-6 max-w-7xl mx-auto space-y-20">
    <!-- Title -->
    <div class="space-y-6 text-center max-w-3xl mx-auto">
        <div class="flex flex-col items-center gap-2">
            <h2 class="text-4xl md:text-5xl font-bold text-brand-dark-green">
                Proyectos destacados
            </h2>
            <div class="h-1.5 w-24 bg-brand-light-green rounded-full"></div>
        </div>
        <p class="text-neutral-600 text-lg">
            Una selección de proyectos donde he aplicado mi experiencia en
            product management, diseño y automatización
        </p>

        <div class="hidden flex-col items-center pt-2 gap-4">
            <p class="text-neutral-500 text-sm">
                ¿Quieres ver más proyectos o conocer el proceso detrás de cada
                uno?
            </p>
            <a
                href="#"
                class="inline-flex items-center gap-2 font-semibold text-brand-dark-green bg-brand-light-green px-6 py-3 rounded-lg hover:bg-brand-green hover:text-white transition-colors"
            >
                Ver portafolio completo
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="w-4 h-4"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                    ></path>
                </svg>
            </a>
        </div>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Project 1 -->
        <article
            class="group bg-white rounded-3xl overflow-hidden border border-neutral-200 shadow-sm hover:shadow-lg transition-all"
        >
            <!-- Image -->
            <div class="relative overflow-hidden aspect-[16/9] bg-[#546A76]">
                <div
                    class="absolute inset-0 bg-gradient-to-t from-[#546A76]/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10"
                >
                </div>
                <img
                    src="https://brilliant-marmot-918.convex.cloud/api/storage/74a5cc37-185c-4cf7-b45a-448381f03359"
                    alt="Promotarjetas.site UI Mockup"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
            </div>

            <div class="p-8 space-y-6">
                <div>
                    <h3
                        class="text-2xl font-bold text-brand-dark-green mb-3 group-hover:text-brand-green transition-colors"
                    >
                        Promotarjetas.site
                    </h3>
                    <p class="text-neutral-600 text-sm leading-relaxed">
                        Plataforma agregadora diseñada para centralizar ofertas y promociones exclusivas para usuarios de tarjetas 
                        de crédito de los principales bancos de El Salvador (BAC Credomatic, Banco Agrícola y Banco Cuscatlán). 
                    </p>
                </div>

                <!-- Tags -->
                <div class="flex flex-wrap gap-2">
                    <span
                        class="px-3 py-1 bg-neutral-100 text-neutral-600 text-xs font-semibold rounded-md border border-neutral-200"
                        >UI/UX Design</span
                    >
                    <span
                        class="px-3 py-1 bg-neutral-100 text-neutral-600 text-xs font-semibold rounded-md border border-neutral-200"
                        >React / SPA</span
                    >
                    <span
                        class="px-3 py-1 bg-neutral-100 text-neutral-600 text-xs font-semibold rounded-md border border-neutral-200"
                        >Product Strategy</span
                    >
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-3 pt-2">
                    <a
                        href="https://promotarjetas.site/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="px-5 py-2.5 bg-brand-light-green text-brand-dark-green text-sm font-bold rounded-lg hover:bg-brand-green hover:text-white transition-colors flex items-center gap-2"
                    >
                        Visitar sitio
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-3.5 h-3.5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </article>
    </div>
</section>
