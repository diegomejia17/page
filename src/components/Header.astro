<header
    class="fixed top-0 left-0 w-full z-50 bg-brand-bg/80 backdrop-blur-md border-b border-brand-dark-green/10"
>
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <!-- Logo -->
        <a
            href="#"
            class="flex items-center gap-2 font-bold text-xl text-brand-charcoal"
        >
            <div
                class="w-8 h-8 bg-brand-green rounded-lg flex items-center justify-center text-white text-sm"
            >
                DM
            </div>
            Diego Mejía
        </a>

        <!-- Desktop Nav -->
        <nav
            class="hidden md:flex items-center gap-8 text-sm font-medium text-brand-charcoal/80"
        >
            <a href="#inicio" class="hover:text-brand-green transition-colors"
                >Inicio</a
            >
            <a href="#sobre-mi" class="hover:text-brand-green transition-colors"
                >Sobre mí</a
            >
            <a
                href="#proyectos"
                class="hover:text-brand-green transition-colors">Proyectos</a
            >
            <a href="#contacto" class="hover:text-brand-green transition-colors"
                >Contacto</a
            >
        </nav>

        <!-- Resume Button -->
        <a
            href="#"
            class="hidden md:block px-5 py-2 bg-brand-light-green text-brand-charcoal font-semibold rounded-full text-sm hover:bg-brand-green hover:text-white transition-colors"
        >
            Curriculum Vitae
        </a>

        <!-- Mobile Menu Button (Placeholder for interactivity later) -->
        <button class="md:hidden text-brand-charcoal">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-6 h-6"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
            </svg>
        </button>
    </div>
</header>
